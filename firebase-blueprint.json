{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with stats and level",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "name": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "description": "User's email address" },
        "level": { "type": "integer", "description": "User's current level" },
        "xp": { "type": "integer", "description": "User's current experience points" },
        "totalQuests": { "type": "integer", "description": "Total number of quests created" },
        "activeQuests": { "type": "integer", "description": "Number of currently active quests" },
        "registrations": { "type": "integer", "description": "Number of quests the user is registered for" },
        "weeklyQuests": { "type": "integer", "description": "Number of quests completed this week" }
      },
      "required": ["uid", "name", "email", "level", "xp"]
    },
    "profiles": {
      "title": "Profile",
      "description": "Public user profile for ranking",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "xp": { "type": "integer" },
        "level": { "type": "integer" },
        "totalQuests": { "type": "integer" }
      },
      "required": ["uid", "name", "xp", "level", "totalQuests"]
    },
    "Quest": {
      "title": "Quest",
      "description": "A learning activity or mission",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the quest" },
        "title": { "type": "string", "description": "Title of the quest" },
        "description": { "type": "string", "description": "Description of the quest" },
        "author": { "type": "string", "description": "Name of the creator" },
        "authorEmail": { "type": "string", "description": "Email of the creator" },
        "authorUid": { "type": "string", "description": "UID of the creator" },
        "date": { "type": "string", "description": "Date of the quest (YYYY-MM-DD)" },
        "startTime": { "type": "string", "description": "Start time of the quest (HH:MM)" },
        "maxParticipants": { "type": "integer", "description": "Maximum number of participants" },
        "currentParticipants": { "type": "integer", "description": "Current number of participants" },
        "tools": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "Tools or platforms used"
        },
        "status": { 
          "type": "string", 
          "enum": ["Criada", "Em Progresso", "Concluída"],
          "description": "Current status of the quest"
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "description", "author", "authorEmail", "authorUid", "date", "startTime", "maxParticipants", "status"]
    },
    "Activity": {
      "title": "Activity",
      "description": "System activity log",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["level_up", "new_quest", "quest_completed"] },
        "userName": { "type": "string" },
        "userUid": { "type": "string" },
        "questTitle": { "type": "string" },
        "questId": { "type": "string", "description": "ID of the related quest" },
        "level": { "type": "integer" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "userName", "userUid", "timestamp"]
    }
  },
  "firestore": {
    "/profiles/{userId}": {
      "schema": "profiles",
      "description": "Public profiles for ranking"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "/quests/{questId}": {
      "schema": "Quest",
      "description": "Collection of available quests"
    },
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "System-wide activity feed"
    }
  }
}
