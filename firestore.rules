rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "azzaspowerbi@gmail.com");
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (
        isOwner(userId) || 
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalStars', 'ratingCount'])
      );
      allow delete: if isAdmin();
    }
    
    // Profiles collection (public info for ranking)
    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (
        isOwner(userId) || 
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalStars', 'ratingCount'])
      );
      allow delete: if isAdmin();
    }
    
    // Quests collection
    match /quests/{questId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.authorUid == request.auth.uid || 
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ratedBy', 'rating', 'currentParticipants', 'participantUids', 'totalQuestStars'])
      );
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.authorUid == request.auth.uid);
    }

    // Activities collection
    match /activities/{activityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userUid == request.auth.uid);
    }

    // Default deny for everything else
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
